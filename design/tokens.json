{
  "$schema": "https://tr.designtokens.org/format/tokens.schema.json",
  "$description": "Lime design tokens (W3C DTCG). Limey digital-card kit — cream + ink + acid lime, Bricolage Grotesque display, mono labels, RTL-ready.",
  "color": {
    "$type": "color",
    "brand": {
      "50": { "$value": "#f8ffe5" },
      "100": { "$value": "#eeffb8" },
      "200": { "$value": "#e1ff80" },
      "300": { "$value": "#d3f94d" },
      "400": { "$value": "#c8f135" },
      "500": { "$value": "#a8d119" },
      "600": { "$value": "#84a300" },
      "700": { "$value": "#5f7600" }
    },
    "light": {
      "background": { "$value": "#f5f3ea" },
      "foreground": { "$value": "#0f0f0c" },
      "card": { "$value": "#ffffff" },
      "muted": { "$value": "#ece9dd" },
      "muted-foreground": { "$value": "#6b6a5e" },
      "border": { "$value": "#e2ded0" },
      "primary": { "$value": "#c8f135" },
      "primary-foreground": { "$value": "#0f0f0c" },
      "ink": { "$value": "#0e0e0b" },
      "mark": { "$value": "#c8f135" }
    },
    "dark": {
      "background": { "$value": "#0e0e0b" },
      "foreground": { "$value": "#f4f3ea" },
      "card": { "$value": "#18180f" },
      "muted": { "$value": "#1f1f15" },
      "border": { "$value": "#2b2b1e" },
      "primary": { "$value": "#c8f135" }
    }
  },
  "font": {
    "$type": "fontFamily",
    "display": { "$value": ["Bricolage Grotesque", "Thmanyah Sans", "sans-serif"] },
    "sans": { "$value": ["Inter", "Cairo", "sans-serif"] },
    "mono": { "$value": ["JetBrains Mono", "monospace"] }
  },
  "radius": {
    "$type": "dimension",
    "$description": "Generously rounded — never square. Maps to rounded-sm/md/lg/xl.",
    "sm": { "$value": "0.85rem" },
    "DEFAULT": { "$value": "1.5rem" },
    "lg": { "$value": "2rem" },
    "xl": { "$value": "2.75rem" }
  }
}
